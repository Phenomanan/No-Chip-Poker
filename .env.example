# Comma-separated list of allowed origins for HTTP + Socket.IO
# Use * for local testing only.
CORS_ORIGINS=http://localhost:3001,https://your-username.github.io,https://your-username.github.io/No-Chip-Poker

# Optional API protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Durable state snapshots and stale room cleanup
STATE_FILE_PATH=./data/state.json
ROOM_TTL_MS=86400000
ROOM_CLEANUP_INTERVAL_MS=300000
